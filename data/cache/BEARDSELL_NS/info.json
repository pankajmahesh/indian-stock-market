{"address1": "No.47, Greams Road", "city": "Chennai", "zip": "600006", "country": "India", "phone": "91 44 2829 3296", "fax": "91 44 2829 0391", "website": "https://beardsell.co.in", "industry": "Building Products & Equipment", "industryKey": "building-products-equipment", "industryDisp": "Building Products & Equipment", "sector": "Industrials", "sectorKey": "industrials", "sectorDisp": "Industrials", "longBusinessSummary": "Beardsell Limited manufactures and supplies expanded polystyrene (EPS) products and prefabricated buildings for various industrial applications in India and internationally. It operates through two segments, Insulation and Trading. The company offers prefabricated panels and thermocole; clean room panels comprising polyurethane foam (PUF)/polyisocyanurate foam (PIR), rock wool, EPS, and modular panels; cold room panels consisting of PUF/PIR and EPS cold room panels; scientific, metal, emergency exit, and fire rated doors; and double and single glazed view windows. It also provides process insulation products comprising EPS pipe section and slabs, as well as PUF slab, pipe sections, and support; building insulation products consisting of EPS/PUF slabs, under and above deck insulation, false ceiling, inner-wall insulation, and insulated partitions; packaging products under the METOPLAST and IGLOO brands, as well as EPS boxes; and QuikBuild 3D panels, geofoam, and EPS blocks for construction applications. In addition, the company offers industrial painting, HVAC ducting, and epoxy flooring services; installation and commissioning services; logistics, warehousing, and supply chain management services; and comprehensive maintenance programs for both corrective and preventive applications. Further, it trades in motors; and exports fabrics, telemedicine equipment, information technology products, medical devices, and educational and laboratory equipment, etc. to various Asian and African nations. Additionally, the company undertakes erection, commissioning, and maintenance works in the field of hot and cold insulation solution. It serves the pharmaceutical, food processing, warehousing, electronics packaging, cold chain, HVAC, and insulation industries. Beardsell Limited was incorporated in 1936 and is based in Chennai, India.", "companyOfficers": [{"maxAge": 1, "name": "Mr. Amrith  Anumolu", "age": 47, "title": "MD & Executive Director", "yearBorn": 1978, "fiscalYear": 2025, "totalPay": 4835440, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Ms. Jayasree  Anumolu", "age": 71, "title": "Whole-Time Director", "yearBorn": 1954, "fiscalYear": 2025, "totalPay": 6666000, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Vinjamoore Varadhan Sridharan", "age": 72, "title": "Chief Financial Officer", "yearBorn": 1953, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. M. E. Chandran", "title": "Chief Operating Officer", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Kanhu Charan Sahu", "age": 49, "title": "Company Secretary & Compliance Officer", "yearBorn": 1976, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}], "compensationAsOfEpochDate": 1767139200, "executiveTeam": [], "maxAge": 86400, "priceHint": 2, "previousClose": 22.92, "open": 22.86, "dayLow": 22.81, "dayHigh": 24.85, "regularMarketPreviousClose": 22.92, "regularMarketOpen": 22.86, "regularMarketDayLow": 22.81, "regularMarketDayHigh": 24.85, "dividendRate": 0.1, "dividendYield": 0.42, "exDividendDate": 1758499200, "payoutRatio": 0.0442, "fiveYearAvgDividendYield": 0.43, "beta": -0.43, "trailingPE": 10.411505, "volume": 19589, "regularMarketVolume": 19589, "averageVolume": 20133, "averageVolume10days": 28970, "averageDailyVolume10Day": 28970, "bid": 0.0, "ask": 0.0, "bidSize": 0, "askSize": 0, "marketCap": 927952640, "nonDilutedMarketCap": 927952610, "fiftyTwoWeekLow": 22.51, "fiftyTwoWeekHigh": 38.6, "allTimeHigh": 93