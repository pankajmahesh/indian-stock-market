{"address1": "Plot No. 85 A, B, D, E & 2923, 2924 A&B", "address2": "E-Road, Phase-I, GIDC Dist. Valsad", "city": "Vapi", "zip": "396195", "country": "India", "website": "https://www.modisonltd.com", "industry": "Electrical Equipment & Parts", "industryKey": "electrical-equipment-parts", "industryDisp": "Electrical Equipment & Parts", "sector": "Industrials", "sectorKey": "industrials", "sectorDisp": "Industrials", "longBusinessSummary": "Modison Limited, together with its subsidiaries, manufactures and sells electrical contacts for low, medium, and high voltage switchgear industries in India and internationally. The company offers low voltage electrical contacts, such as silver tin oxide; silver brazing alloy; silver, steel, ni, and cupro nickel backed contracts; fine silver powder and granules; solid and bimetal rivets; silver cadmium oxide; silver graphite; silver inlay, edge lay, overlay, through lay, and top lay in copper and brass; silver tungsten and silver tungsten carbide; silver alloy wires; silver bimetal crown; and silver welded assembly for low voltage electrical contacts. It also provides medium and high voltage electrical contacts, including eutectic brazing alloys; copper chromium discs; cast on plugs and segments; copper chromium zirconium contacts; copper tungsten and brazed arcing contracts; and electron-beam welding. In addition, the company offers precious metal compounds comprising silver oxide, nitrate, and sulphate; and silver bullion products, such as casted silver, minted silver, and silver cutlery. Further, it provides refining and recovery of precious metals; melting and assaying of silver; silver plating; electron beam welding; and research and development of contract materials for special applications. The company serves the industrial motors, transmission and distribution, railway, aerospace, automotive, marine, defense, engineering, life science, and pharmaceutical industries. The company was formerly known as Modison Metals Limited and changed its name to Modison Limited in July 2022. Modison Limited was founded in 1965 and is based in Vapi, India.", "companyOfficers": [{"maxAge": 1, "name": "Mr. Ramesh Mangilal Kothari", "title": "Chief Financial Officer", "fiscalYear": 2025, "totalPay": 2676000, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Ms. Pooja Birendra Sinha", "title": "Company Secretary & Compliance Officer", "fiscalYear": 2025, "totalPay": 174000, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Girdhari Lal Modi", "age": 84, "title": "MD & Executive Director", "yearBorn": 1941, "fiscalYear": 2025, "totalPay": 36377000, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Rajkumar Mohanlal Modi", "age": 60, "title": "Joint MD & Whole-Time Director", "yearBorn": 1965, "fiscalYear": 2025, "totalPay": 25121000, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Kumar Jay Modi", "age": 47, "title": "Joint MD & Whole Time Director", "yearBorn": 1978, "fiscalYear": 2025, "totalPay": 24805000, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Murlidhar Narayan Nikam", "title": "Chief Executive Officer", "fiscalYear": 2025, "totalPay": 7116000, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Nitin Vaijanath Kulkarni", "title": "Plant Head", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Kiritkumar Mohanbhai Patel", "title": "Plant Head", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}], "compensationAsOfEpochDate": 1767139200, "executiveTeam": [], "maxAge": 86400, "priceHint": 2, "previousClose": 125.96, "open": 125.01, "dayLow": 119.75, "dayHigh": 125.01, "regularMarketPreviousClose": 125.96, "regularMarketOpen": 125.01, "regularMarketDayLow": 119.75, "regularMarketDayHigh": 125.01, "dividendRate": 5.0, "dividendYield": 3.97, "exDividendDate": 1765152000, "payoutRatio": 0.4225, "beta": 0.175, "trailing