odara, India.", "fullTimeEmployees": 1757, "companyOfficers": [{"maxAge": 1, "name": "Mr. Deepak Chimanlal Mehta B.Sc.", "age": 69, "title": "Chairman & MD", "yearBorn": 1956, "fiscalYear": 2025, "totalPay": 86000000, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Maulik Deepak Mehta", "age": 42, "title": "CEO & Executive Director", "yearBorn": 1983, "fiscalYear": 2025, "totalPay": 49500000, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Somsekhar Asimkumar Nanda", "age": 58, "title": "CFO & Chief Risk Officer", "yearBorn": 1967, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Sanjay B. Upadhyay", "age": 64, "title": "Director of Finance, Group CFO & Whole-Time Director", "yearBorn": 1961, "fiscalYear": 2025, "totalPay": 59700000, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Girish R. Satarkar", "age": 61, "title": "President of BI & Executive Director", "yearBorn": 1964, "fiscalYear": 2025, "totalPay": 24300000, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Jagdeep Amritlal Vyas", "age": 65, "title": "Senior General Manager of Accounts & Taxation", "yearBorn": 1960, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Subash  Dhar", "title": "Head of Technology", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. K. C. Bahuguna", "title": "Chief Information Officer", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Arvind  Bajpai", "age": 53, "title": "Company Secretary & Compliance Officer", "yearBorn": 1972, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Subimat  Mondal", "title": "Group Chief Human Resource Officer", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}], "compensationAsOfEpochDate": 1767139200, "executiveTeam": [], "maxAge": 8640