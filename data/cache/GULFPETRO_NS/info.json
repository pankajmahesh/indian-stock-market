{"address1": "804, Ackruti Star", "address2": "8th Floor MIDC Central Rd, Opp. Ackruti Ctr Point MIDC, Andheri (East)", "city": "Mumbai", "zip": "400093", "country": "India", "phone": "91 22 6148 2500", "fax": "91 22 6148 2599", "website": "https://www.gppetroleums.co.in", "industry": "Oil & Gas Refining & Marketing", "industryKey": "oil-gas-refining-marketing", "industryDisp": "Oil & Gas Refining & Marketing", "sector": "Energy", "sectorKey": "energy", "sectorDisp": "Energy", "longBusinessSummary": "GP Petroleums Limited formulates, manufactures, and markets industrial and automotive lubricants, rubber process oils, transformer oils, greases, and other specialties in India. It operates through the Manufacturing and Trading segments. The company offers automotive lubricants, including automotive and diesel engine oils, gear and transmission oils, greases, passenger car motor and motorcycle oils, engine coolant, and brake fluids; and trades in base oil, fuel oil, and bitumen. It also provides industrial lubricants, such as industrial lubricating oils; metal working fluids; corrosion preventive, hydraulic, spindle, slideway, and turbine oils; cleaners and quenching oils; industrial greases; and horticultural orchard spray oils; and a suite of metalworking fluids, including soluble cutting oils, semi-synthetic coolants, neat and water-soluble cleaners, neat cutting oils, mist oils, spark erosion oils, quenching oils, rust preventives, as well as specialty oils, such as thermic fluids, crack detection oils, and plunger lubrication oils. The company also sells rubber process oils, such as aromatic, naphthenic, paraffinic, and low PCA oils. It distributes its products to automotive and industrial OEMs, auto component manufacturers, rubber and plastic product manufacturers, and tyre companies; and general engineering, metal processing, textiles, cement, sugar, rubber, and mining sectors under the IPOL and REPSOL brand names through distributors and retail outlets. The company also exports its products. GP Petroleums Limited was formerly known as Sah Petroleums Limited and changed its name to GP Petroleums Limited in April 2015. The company was founded in 1973 and is headquartered in Mumbai, India.", "fullTimeEmployees": 261, "companyOfficers": [{"maxAge": 1, "name": "Mr. Arjun  Verma", "age": 62, "title": "CFO & Executive Director", "yearBorn": 1963, "fiscalYear": 2025, "totalPay": 14440638, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Ms. Kanika Sehgal Sadana", "title": "Company Secretary & Compliance Officer", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Vishnu  Vijay", "title": "Head HR & Admin", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Jogesh  Sharma", "title": "Head of Industrial Lubricants", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Ashish  Parab", "title": "Head of Procurement, Imports & Business Development", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Ms. Pallavi  Garg", "title": "Deputy CFO of Finance & Accounts", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}], "compensationAsOfEpochDate": 1767139200, "executiveTeam": [], "maxAge": 86400, "priceHint": 2, "previousClose": 28.24, "open": 28.1, "dayLow": 27.7, "dayHigh": 28.45, "regularMarketPreviousClose": 28.24, "regularMarketOpen": 28.1, "regularMarketDayLow": 27.7, "regularMarketDayHigh": 28.45, "exDividendDate": 1600646400, "payoutRatio": 0.0, "fiveYearAvgDividendYield": 1.27, "beta": -0.11, "trailingPE": 5.4851484, "volume": 9820, "regularMarketVolume": 9820, "averageVolume": 58308, "averageVolume10days": 93738, "averageDailyVolume10Day": 93738, "bid": 27.71, "ask": 27.75, "bidSize": 0, "askSize": 0, "marketCap": 1434741760, "nonDilutedMarketCap": 1433171006, "fiftyTwoWeekLow": 27.7, "fiftyTwoWeekHigh": 51.95, "allTimeHigh": 103.9, "allTimeLo