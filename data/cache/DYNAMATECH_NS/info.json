uru, India.", "fullTimeEmployees": 869, "companyOfficers": [{"maxAge": 1, "name": "Mr. Udayant  Malhoutra", "age": 60, "title": "CEO, MD & Executive Director", "yearBorn": 1965, "fiscalYear": 2025, "totalPay": 14400000, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Chalapathi  Puramannagari", "title": "CFO & Executive Director", "fiscalYear": 2025, "totalPay": 12000000, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Shivaram  V.", "title": "Chief Legal Officer, Head of Compliance & Company Secretary", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. V.  Ravichander", "title": "Chief Technology Officer", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Lieutenant General Sanjeev  Madhok (Retd.) PVSM, AVSM, VSM", "title": "Head of Defense Business", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Ajay  Gururaj", "title": "Chief Commercial Officer", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Enrico  Fischer", "title": "Managing Director of Eisenwerk Erla GmbH", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Steve  Hayes", "title": "Chief Technical Director Aerospace Division of Dynamatic Limited, UK", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Jayagopal  Gajendra", "title": "Head of Corporate Treasury", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}], "compensationAsOfEpochDate": 1767139200, "executiveTeam": [], "maxAge": 86400, "priceHint": 2, "previousClose": 9080.0, "open": 8949.0, "dayLow": 8949.0, "dayHigh": 9102.0, "regularMarketPreviousClose": 9080.0, "regularMarketOpen": 8949.0, "regularMarketDayLow": 8949.0, "regularMarketDayHigh": 9102.0, "dividendRate": 5.0, "dividendYield": 0.06, "exDividendDate": 1770940800, "payoutRatio": 0.